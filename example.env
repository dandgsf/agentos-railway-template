# Required (default configured for OpenAI)
# OPENAI_API_KEY=sk-***

# Optional: Use a different model provider
# ANTHROPIC_API_KEY=sk-ant-***
# GOOGLE_API_KEY=***

# Optional: comma-separated browser origins allowed to call AgentOS directly
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://your-agent-ui-domain.up.railway.app

# WhatsApp Cloud API (disabled by default to keep tests/dev from hitting Meta)
# Set WHATSAPP_ENABLED=true only when you want the live integration enabled.
WHATSAPP_ENABLED=false
# Get these from https://developers.facebook.com -> your app -> WhatsApp > API Setup
# APP_SECRET_KEY=your-app-secret-key
# WHATSAPP_ACCESS_TOKEN=your-access-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_VERIFY_TOKEN=your-verify-token
# WHATSAPP_APP_SECRET=your-app-secret
# Optional for local webhook debugging only. Do not enable in production.
# WHATSAPP_SKIP_SIGNATURE_VALIDATION=true


# Database (defaults work out of the box)
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai

# NoCoderSon KB loader (used by scripts/load_nocoderson_kb.py)
# Path to the knowledge-base.jsonl export (dev: Google Drive; prod: Railway Volume mount)
# KNOWLEDGE_BASE_JSONL=/mnt/kb/knowledge-base.jsonl
# Optional curated concepts directory (priority-high docs loaded alongside JSONL)
# KNOWLEDGE_BASE_CONCEPTS_DIR=/mnt/kb/concepts
